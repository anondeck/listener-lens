      "minimum_direction_cosine": 0.5,
      "base_vowel_and_rhoticity_components_must_both_pass": true
    },
    "analysis_family": {
      "all_three_formant_ceilings_must_be_measurable": true,
      "exact_requires_exact_at_every_ceiling": true,
      "directional_requires_directional_or_exact_at_every_ceiling": true,
      "one_ceiling_cannot_rescue_another": true
    }
  },
  "aggregation_policy": {
    "slot_exact_requires_every_occurrence_exact_across_every_ceiling": true,
    "slot_directional_requires_every_occurrence_directional_or_exact_across_every_ceiling": true,
    "cell_exact_requires_all_three_slots_and_four_occurrences_exact": true,
    "cell_directional_requires_all_three_slots_and_four_occurrences_directional_or_exact": true,
    "missing_or_excluded_measurement_fails_the_cell": true,
