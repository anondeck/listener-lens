# Local product development defaults to zero paid calls even when this is set.
OPENAI_API_KEY=

# Optional classroom generator. The deployment name is "luna" in the Build
# Week Foundry resource; the endpoint and key remain server-side.
AZURE_FOUNDRY_ENDPOINT=
AZURE_FOUNDRY_API_KEY=
AZURE_FOUNDRY_DEPLOYMENT=luna

# The typed route is served locally by default; set this to false to stop it
# before transformation or cache lookup.
LOCAL_TYPED_AUDIO_SERVE_ENABLED=true

# The retired GPT Audio renderer has no active product route. Local Kokoro
# rendering is enabled only by the exact candidate flag below and makes no API
# call. Foundry classroom generation retains its independent paid-call sentinel.
LOCAL_ACTIVITY_GENERATION_ENABLED=

# Kokoro may be set to true for the local candidate smoke only. It remains false
# in wrangler.jsonc and production. The other candidates are exact-false guards.
KOKORO_ENGLISH_CANDIDATE_ENABLED=false
KOKORO_BILINGUAL_CANDIDATE_ENABLED=false
PORTUGUESE_RENDERER_CANDIDATE_ENABLED=false
RECIPROCAL_LISTENER_LENS_RESEARCH_ENABLED=false
AZURE_LENS_CANDIDATE_ENABLED=false
GIBBERISH_CANDIDATE_ENABLED=false

# Optional local ports.
LOCAL_PORT=8789
TRANSFORM_PORT=8790
